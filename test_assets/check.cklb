          "severity": "medium",
          "rule_version": "FFOX-00-000039",
          "rule_title": "Firefox Studies must be disabled.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\nPolicy Name: Disable Firefox Studies\nPolicy State: Enabled\n\nmacOS \"plist\" file:\n<key>DisableFirefoxStudies</key>\n <true/>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"DisableFirefoxStudies\": true",
          "reference_identifier": null,
          "group_title": "Firefox Studies must be disabled.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Studies try out different features and ideas before they are released to all Firefox users. Testing beta software is not in the DoD user's mission.",
          "check_content": "Type \"about:policies\" in the browser address bar.\n\nIf \"DisableFirefoxStudies\" is not displayed under Policy Name or the Policy Value does not have a value of \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",

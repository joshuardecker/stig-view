          "severity": "medium",
          "rule_version": "FFOX-00-000014",
          "rule_title": "Background submission of information to Mozilla must be disabled.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\nPolicy Name: Disable Telemetry\nPolicy State: Enabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>DisableTelemetry</key>\n<true/>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"DisableTelemetry\": true",
          "reference_identifier": null,
          "group_title": "Background submission of information to Mozilla must be disabled.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Firefox by default sends information about Firefox to Mozilla servers. There should be no background submission of technical and other information from DoD computers to Mozilla with portions posted publicly.",
          "check_content": "Type \"about:policies\" in the browser window.\n\nIf \"DisableTelemetry\" is not displayed under Policy Name or the Policy Value is not \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",

          "severity": "medium",
          "rule_version": "RHEL-08-010760",
          "rule_title": "All RHEL 8 local interactive user accounts must be assigned a home directory upon creation.",
          "fix_text": "Configure RHEL 8 to assign home directories to all new local interactive users by setting the \"CREATE_HOME\" parameter in \"/etc/login.defs\" to \"yes\" as follows.\n\nCREATE_HOME yes",
          "reference_identifier": null,
          "group_title": "All RHEL 8 local interactive user accounts must be assigned a home directory upon creation.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "If local interactive users are not assigned a valid home directory, there is no place for the storage and control of files they should own.",
          "check_content": "Verify all local interactive users on RHEL 8 are assigned a home directory upon creation with the following command:\n\n$ sudo grep -i create_home /etc/login.defs\n\nCREATE_HOME yes\n\nIf the value for \"CREATE_HOME\" parameter is not set to \"yes\", the line is missing, or the line is commented out, this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-230324"

          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000018",
          "rule_title": "Firefox must prevent the user from quickly deleting data.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration >> Administrative Templates >> Mozilla >> Firefox.\nPolicy Name: Disable Forget Button\nPolicy State: Enabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>DisableForgetButton</key>\n<true/>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"DisableForgetButton\": true",
          "reference_identifier": null,
          "group_title": "Firefox must prevent the user from quickly deleting data.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "There should not be an option for a user to \"forget\" work they have done. This is required to meet nonrepudiation controls.",
          "check_content": "Enter \"about:policies\" in the browser address bar.\n\nIf \"DisableForgetButton\" is not displayed under Policy Name or the Policy Value is not \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251562"
          ],
          "ccis": [
            "CCI-000166"
          ],

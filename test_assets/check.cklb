        {
          "uuid": "01191d30-d723-4f7f-8e11-ff0698e94125",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251563",
          "group_id_src": "V-251563",
          "rule_id": "SV-251563r960963",
          "rule_id_src": "SV-251563r960963_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000019",
          "rule_title": "Firefox private browsing must be disabled.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\nPolicy Name: Disable Private Browsing\nPolicy State: Enabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>DisablePrivateBrowsing</key>\n<true/>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"DisablePrivateBrowsing\": true",
          "reference_identifier": null,
          "group_title": "Firefox private browsing must be disabled.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Private browsing allows the user to browse the internet without recording their browsing history/activity. From a forensics perspective, this is unacceptable. Best practice requires that browser history is retained.",
          "check_content": "Type \"about:policies\" in the browser window.\n\nIf \"DisablePrivateBrowsing\" is not displayed under Policy Name or the Policy Value is not \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251563"
          ],
          "ccis": [
            "CCI-000381"
          ],
          "group_tree": [
            {
              "id": "V-251563",
              "title": "SRG-APP-000141",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "open",
          "overrides": {},
          "comments": "Mozilla Firefox is not configured to disable private browsing.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "19a08a47-1344-4f9a-be05-7e0c19c43ddd",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251571",
          "group_id_src": "V-251571",
          "rule_id": "SV-251571r960963",
          "rule_id_src": "SV-251571r960963_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000027",
          "rule_title": "Firefox deprecated ciphers must be disabled.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\\Disabled Ciphers\nPolicy Name: TLS_RSA_WITH_3DES_EDE_CBC_SHA\nPolicy State: Enabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>DisabledCiphers</key>\n  <dict>\n    <key>TLS_RSA_WITH_3DES_EDE_CBC_SHA</key>\n    <true/>\n  </dict>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"DisabledCiphers\": {\n  \"TLS_RSA_WITH_3DES_EDE_CBC_SHA\": true\n}",
          "reference_identifier": null,
          "group_title": "Firefox deprecated ciphers must be disabled.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "A weak cipher is defined as an encryption/decryption algorithm that uses a key of insufficient length. Using an insufficient length for a key in an encryption/decryption algorithm opens up the possibility (or probability) that the encryption scheme could be broken.",
          "check_content": "Type \"about:policies\" in the browser address bar.\n\nIf \"DisabledCiphers\" is not displayed under Policy Name or the Policy Value is not \"TLS_RSA_WITH_3DES_EDE_CBC_SHA\" with a value of  \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251571"
          ],
          "ccis": [
            "CCI-000381"
          ],
          "group_tree": [
            {
              "id": "V-251571",
              "title": "SRG-APP-000141",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "open",
          "overrides": {},
          "comments": "Mozilla Firefox is not configured to disable the 'TLS_RSA_WITH_3DES_EDE_CBC_SHA' cipher.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "1a817025-6240-4936-9d3f-afb1319e8a7a",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251545",
          "group_id_src": "V-251545",
          "rule_id": "SV-251545r1117151",
          "rule_id_src": "SV-251545r1117151_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "high",
          "rule_version": "FFOX-00-000001",
          "rule_title": "The installed version of Firefox must be supported.",
          "fix_text": "Upgrade the version of the browser to an approved version by obtaining software from the vendor or other trusted source.",
          "reference_identifier": null,
          "group_title": "The installed version of Firefox must be supported.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Using versions of an application that are not supported by the vendor is not permitted. Vendors respond to security flaws with updates and patches. These updates are not available for unsupported versions, which can leave the application vulnerable to attack.",
          "check_content": "Run Firefox. Click the ellipsis button >> Help >> About Firefox, and view the version number.\n\nIf the Firefox version is not a supported version, this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251545"
          ],
          "ccis": [
            "CCI-002605"
          ],
          "group_tree": [
            {
              "id": "V-251545",
              "title": "SRG-APP-000456",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "not_reviewed",
          "overrides": {},
          "comments": "",
          "finding_details": "#rpm -qa | grep -i firefox\nfirefox-140.8.0-2.el8_10.x86_64\n"
        },
        {
          "uuid": "1bb7ab7e-3367-4ca2-99eb-5e41a9073ed2",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251552",
          "group_id_src": "V-251552",
          "rule_id": "SV-251552r960963",
          "rule_id_src": "SV-251552r960963_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000008",
          "rule_title": "Firefox must be configured to not use a password store with or without a master password.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\nPolicy Name: PasswordManager\nPolicy State: Disabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>PasswordManagerEnabled</key>\n<false/>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"PasswordManagerEnabled\": false",
          "reference_identifier": null,
          "group_title": "Firefox must be configured to not use a password store with or without a master password.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Firefox can be set to store passwords for sites visited by the user. These individual passwords are stored in a file and can be protected by a master password. Autofill of the password can then be enabled when the site is visited. This feature could also be used to autofill the certificate PIN, which could lead to compromise of DoD information.",
          "check_content": "Type \"about:policies\" in the browser window.\n\nIf \"PasswordManagerEnabled\" is not displayed under Policy Name or the Policy Value is not \"false\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251552"
          ],
          "ccis": [
            "CCI-000381"
          ],
          "group_tree": [
            {
              "id": "V-251552",
              "title": "SRG-APP-000141",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "open",
          "overrides": {},
          "comments": "Mozilla Firefox is not configured to disable the password manager.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "1cfb380b-92b7-4549-85d7-825936544788",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251547",
          "group_id_src": "V-251547",
          "rule_id": "SV-251547r1067550",
          "rule_id_src": "SV-251547r1067550_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000003",
          "rule_title": "Firefox must be configured to ask which certificate to present to a website when a certificate is required.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\\\nPolicy Name: Preferences\nPolicy State: Enabled\nPolicy Value:\n{\n  \"security.default_personal_cert\": {\n    \"Value\": \"Ask Every Time\",\n    \"Status\": \"locked\"\n  }\n}\n\nmacOS \"plist\" file:\nAdd the following:\n<key>Preferences</key>\n<dict>\n  <key>security.default_personal_cert</key>\n  <dict>\n    <key>Value</key>\n    <string>Ask Every Time</string>\n    <key>Status</key>\n    <string>locked</string>\n  </dict>\n</dict>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"Preferences\": {\n  \"security.default_personal_cert\": {\n    \"Value\": \"Ask Every Time\",\n    \"Status\": \"locked\"\n  }\n}",
          "reference_identifier": null,
          "group_title": "Firefox must be configured to ask which certificate to present to a website when a certificate is required.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "When a website asks for a certificate for user authentication, Firefox must be configured to have the user choose which certificate to present. Websites within DOD require user authentication for access, which increases security for DOD information. Access will be denied to the user if certificate management is not configured.",
          "check_content": "Type \"about:policies\" in the browser address bar.\n\nIf \"Preferences\" is not displayed under Policy Name and the Policy Value does not include \"security.default_personal_cert\" with a value of \"Ask Every Time\" and status of \"locked\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251547"
          ],
          "ccis": [
            "CCI-000187"
          ],
          "group_tree": [
            {
              "id": "V-251547",
              "title": "SRG-APP-000177",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "open",
          "overrides": {},
          "comments": "Mozilla Firefox is not configured to prompt the user to choose which certificate to present to a web site when a certificate is required.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "1fabaef2-55e5-4858-b5a3-fdf0321c7c26",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251567",
          "group_id_src": "V-251567",
          "rule_id": "SV-251567r960963",
          "rule_id_src": "SV-251567r960963_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000023",
          "rule_title": "Firefox fingerprinting protection must be enabled.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\\Tracking Protection\nPolicy Name: Fingerprinting\nPolicy State: Enabled\n\nmacOS \"plist\" file:\nAdd the following:\n<key>EnableTrackingProtection</key>\n  <dict>\n    <key>Fingerprinting</key>\n <true/>\n  </dict>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"EnableTrackingProtection\": {\n  \"Fingerprinting\": true\n}",
          "reference_identifier": null,
          "group_title": "Firefox fingerprinting protection must be enabled.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "The Content Blocking/Tracking Protection feature stops Firefox from loading content from malicious sites. The content might be a script or an image, for example. If a site is on one of the tracker lists that Firefox is set to use, the fingerprinting script (or other tracking script/image) will not be loaded from that site.\n\nFingerprinting scripts collect information about browser and device configuration, such as operating system, screen resolution, and other settings. By compiling these pieces of data, fingerprinters create a unique profile that can be used to track the user around the web.",
          "check_content": "Type \"about:policies\" in the browser address bar.\n\nIf \"EnableTrackingProtection\" is not displayed under Policy Name or the Policy Value is not \"Fingerprinting\"  with a value of \"true\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251567"
          ],
          "ccis": [
            "CCI-000381"
          ],
          "group_tree": [
            {
              "id": "V-251567",
              "title": "SRG-APP-000141",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "open",
          "overrides": {},
          "comments": "Mozilla Firefox is not configured to enable Fingerprinting protection.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "217146b1-58b7-4f76-a74a-2aa76e5a6dd4",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251565",
          "group_id_src": "V-251565",

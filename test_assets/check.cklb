          "overrides": {},
          "comments": "Mozilla Firefox is not configured to disable feedback reporting.",
          "finding_details": "#if [ -e /etc/firefox/policies/policies.json ];\nthen\n    echo \"/etc/firefox/policies/policies.json exists.\"\n    echo \"***XYLOK ICS***\"\n    cat /etc/firefox/policies/policies.json\nelse\n    echo \"/etc/firefox/policies/policies.json does not exist.\"\n    echo \"***XYLOK ICS***\"\n    if [ -e \"$ffinstloc/distribution/policies.json\" ];\n    then\n        echo \"$ffinstloc/distribution/policies.json exists.\"\n        echo \"***XYLOK ICS***\"\n        cat \"$ffinstloc/distribution/policies.json\"\n    else\n        echo \"$ffinstloc/distribution/policies.json does not exist.\"\n    fi\nfi\n\n\ud83d\udd0d /etc/firefox/policies/policies.json does not exist.\n\u274c /usr/lib64/firefox/distribution/policies.json does not exist.\n\n\nXylok post-processing completed with no errors.\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "7e79c50a-1057-4448-ab33-4c0ea3489ada",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",
          "group_id": "V-251548",
          "group_id_src": "V-251548",
          "rule_id": "SV-251548r1067552",
          "rule_id_src": "SV-251548r1067552_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000004",
          "rule_title": "Firefox must be configured to not automatically check for updated versions of installed search plugins.",
          "fix_text": "Windows group policy:\n1. Open the group policy editor tool with \"gpedit.msc\".\n2. Navigate to Policy Path: Computer Configuration\\Administrative Templates\\Mozilla\\Firefox\\\nPolicy Name: Preferences\nPolicy State: Enabled\nPolicy Value:\n{\n  \"browser.search.update\": {\n    \"Value\": false,\n    \"Status\": \"locked\"\n  }\n}\n\nmacOS \"plist\" file:\nAdd the following:\n<key>Preferences</key>\n<dict>\n  <key>browser.search.update</key>\n  <dict>\n    <key>Value</key>\n    <false/>\n    <key>Status</key>\n    <string>locked</string>\n  </dict>\n</dict>\n\nLinux \"policies.json\" file:\nAdd the following in the policies section:\n\"Preferences\": {\n  \"browser.search.update\": {\n    \"Value\": false,\n    \"Status\": \"locked\"\n  }\n}",
          "reference_identifier": null,
          "group_title": "Firefox must be configured to not automatically check for updated versions of installed search plugins.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Updates must be controlled and installed from authorized and trusted servers. This setting overrides a number of other settings that may direct the application to access external URLs.",
          "check_content": "Type \"about:policies\" in the browser address bar.\n\nIf \"Preferences\" is not displayed under Policy Name or the Policy Value does not include \"browser.search.update\" with a value of  \"false\" and status of \"locked\", this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251548"
          ],
          "ccis": [
            "CCI-000381"
          ],

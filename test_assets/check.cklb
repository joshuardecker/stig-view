          "rule_id_src": "SV-251550r961194_rule",
          "target_key": null,
          "stig_ref": null,
          "weight": "10.0",
          "classification": "Unclassified",
          "severity": "medium",
          "rule_version": "FFOX-00-000006",
          "rule_title": "Firefox must be configured to not automatically execute or download MIME types that are not authorized for auto-download.",
          "fix_text": "Remove any unauthorized extensions from the auto-download list.",
          "reference_identifier": null,
          "group_title": "Firefox must be configured to not automatically execute or download MIME types that are not authorized for auto-download.",
          "false_positives": "",
          "false_negatives": "",
          "discussion": "Some files can be downloaded or execute without user interaction. This setting ensures these files are not downloaded and executed.",
          "check_content": "Type \"about:preferences\" in the browser address bar.\n\nType \"Applications\" in the Find bar in the upper-right corner.\n\nDetermine if any of the following file extensions are listed: HTA, JSE, JS, MOCHA, SHS, VBE, VBS, SCT, WSC, FDF, XFDF, LSL, LSO, LSS, IQY, RQY, DOS, BAT, PS, EPS, WCH, WCM, WB1, WB3, WCH, WCM, AD.\n\nIf the entry exists and the \"Action\" is \"Save File\" or \"Always Ask\", this is not a finding.\n\nIf an extension exists and the entry in the Action column is associated with an application that does/can execute the code, this is a finding.",
          "documentable": "",
          "mitigations": "",
          "potential_impacts": "",
          "third_party_tools": "Xylok",
          "mitigation_control": "",
          "responsibility": "",
          "security_override_guidance": "",
          "ia_controls": "",
          "check_content_ref": null,
          "legacy_ids": [
            "V-251550"
          ],
          "ccis": [
            "CCI-001242"
          ],
          "group_tree": [
            {
              "id": "V-251550",
              "title": "SRG-APP-000278",
              "description": "<GroupDescription></GroupDescription>"
            }
          ],
          "createdAt": "2026-03-28T04:09:31Z",
          "updatedAt": "2026-03-28T04:09:31Z",
          "status": "not_reviewed",
          "overrides": {},
          "comments": "",
          "finding_details": "#Are any of the extensions listed present in any plugin's suffixes column, and associated with an application that can execute code?\n\n"
        },
        {
          "uuid": "b5f4d411-4bf2-499f-88e4-8c0ef2cc95c0",
          "stig_uuid": "db7deaa8-52d9-4848-86ba-916c3bd75e68",

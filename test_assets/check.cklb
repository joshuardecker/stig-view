          "finding_details": "#echo '***XYLOK ICS***'\nsystemctl status auditd.service | grep Active:\n\nChecking if the 'auditd.service' is 'ruuning' and 'active':\n\u2705 Active: active (running) since Fri 2026-03-27 21:33:48 MDT; 35min ago\n\n\nXylok post-processing completed with no errors.\n"
        },
        {
          "uuid": "0b9803b2-298b-444f-a59f-e610d34d67bc",
          "stig_uuid": "e27566b5-e7a8-44d8-8939-9d31f0f583f8",

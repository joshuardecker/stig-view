          <ATTRIBUTE_DATA>CCI-000169</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STATUS>Open</STATUS>
        <FINDING_DETAILS>#echo "***XYLOK ICS***"
auditctl -l | grep "path=/usr/bin/gpasswd"


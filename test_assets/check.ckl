        <STATUS>NotAFinding</STATUS>
        <FINDING_DETAILS>#while IFS=: read -r username _ _ _ _ home_dir shell; do
    if [[ "$shell" != "/sbin/nologin" &amp;&amp; "$shell" != "/sbin/halt" &amp;&amp; "$shell" != "/bin/sync" &amp;&amp; "$shell" != "/sbin/shutdown" &amp;&amp; "$shell" != "/bin/false" &amp;&amp; "$shell" != "/bin/true" &amp;&amp; "$shell" != "/usr/sbin/nologin" ]]; then
        group_owner=$(stat -c '%g' "$home_dir")
        primary_group=$(id -g "$username")

        echo "***XYLOK ICS***"
        echo "$username:$home_dir:$group_owner:$primary_group"
    fi
done &lt; /etc/passwd


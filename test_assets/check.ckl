          <ATTRIBUTE_DATA></ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>Documentable</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>false</ATTRIBUTE_DATA>

          <VULN_ATTRIBUTE>Rule_ID</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>SV-230516r958804_rule</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>

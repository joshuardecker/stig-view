        <STATUS>Open</STATUS>
        <FINDING_DETAILS>#echo '***XYLOK ICS***'
cat /etc/passwd
echo '***XYLOK ICS***'
# Get the list of interactive user accounts
user_list=$(awk -F: '{if ($NF != "/usr/sbin/nologin" &amp;&amp; $NF != "/usr/bin/false" &amp;&amp; $NF !="/sbin/nologin" &amp;&amp; $NF != "/sbin/halt" &amp;&amp; $NF != "/bin/sync" &amp;&amp; $NF != "/sbin/shutdown" &amp;&amp; $NF != "/bin/false" &amp;&amp; $NF != "/bin/true" &amp;&amp; $NF != "/usr/sbin/nologin") print $1}' /etc/passwd)

# Loop through each interactive user account
for user in $user_list; do
    # Get the minimum password age in days for the user
    min_age=$(chage --list "$user" | grep "Min" | awk -F: '{print $2}')
    
    # List users and their minpasswordage
    echo "USERNAME:$user \t MINPASSWORDAGE:$min_age"
done

Checking minimum time between password changes for interactive users:
❌ USERNAME:root \t MINPASSWORDAGE: 0
❌ USERNAME:deckerr \t MINPASSWORDAGE: 0


Xylok post-processing completed with no errors.
</FINDING_DETAILS>
        <COMMENTS>The following interactive users have a minimum password lifetime less than 1 (one) day:
root
deckerr</COMMENTS>

cat /etc/passwd
#!/bin/bash
FILENAME="/etc/passwd"
while IFS=: read -r username password userid groupid comment homedir cmdshell
do
        if [[ "$cmdshell" != "/sbin/nologin" &amp;&amp; "$cmdshell" != "/sbin/halt" &amp;&amp; "$cmdshell" != "/bin/sync" &amp;&amp; "$cmdshell" != "/sbin/shutdown" &amp;&amp; "$cmdshell" != "/bin/false" &amp;&amp; "$cmdshell" != "/bin/true" &amp;&amp; "$cmdshell" != "/usr/sbin/nologin" &amp;&amp; "$username" != "root" ]]; then
                echo '***XYLOK ICS***'
                echo "#USERNAME:$username HOMEDIRECTROY:$homedir PRIMARYGROUPID:$groupid"
				echo "$homedir" | awk -F$username '{print substr($1,1,length($1)-1)}' |xargs -I i grep i /etc/fstab
        fi
done &lt; $FILENAME


        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>Responsibility</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA></ATTRIBUTE_DATA>
        </STIG_DATA>

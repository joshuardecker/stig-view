        <FINDING_DETAILS>#echo '***XYLOK ICS***'
echo 'File Name: /etc/sssd/sssd.conf'
sed -n '/^\[sssd\]/,/^$/p' "/etc/sssd/sssd.conf"
directory="/etc/sssd/conf.d"

for file in "$directory"/*; do
    # Check if the file is a regular file
    if [[ -f "$file" ]]; then
        echo "***XYLOK ICS***"
        echo "File Name: $file"
        
        # Extract the [sssd] portion using sed
        sed -n '/^\[sssd\]/,/^$/p' "$file"
    fi
done


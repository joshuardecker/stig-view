grep -Er '^[[:space:]]*kernel.unprivileged_bpf_disabled' /run/sysctl.d/*.conf /usr/local/lib/sysctl.d/*.conf /usr/lib/sysctl.d/*.conf /lib/sysctl.d/*.conf /etc/sysctl.conf /etc/sysctl.d/*.conf 2&gt;/dev/null


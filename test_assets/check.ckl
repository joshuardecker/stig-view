        <FINDING_DETAILS>## Get the list of users excluding those with certain shells or root
users=$(grep -v "/sbin/nologin\|/sbin/halt\|/bin/sync\|/sbin/shutdown\|/bin/false\|/bin/true\|/usr/sbin/nologin\|root" /etc/passwd | cut -d: -f1)

# Iterate through the users and display the account expiration information
for user in $users; do
    # Print delimiter before each user, including before the first one
    echo "***XYLOK ICS***"

    # Display the username and account expiration info
    echo "Username: $user"
    chage -l "$user" | grep -i "account expires"
done


        <STATUS>NotAFinding</STATUS>
        <FINDING_DETAILS>#fstab_file="/etc/fstab"
removable_media_found=false

while read -r line; do
    line=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    if [[ -n "$line" &amp;&amp; ! "$line" =~ ^# ]]; then
        fields=($line)
        mount_point=${fields[1]}

        # Check if the mount point is a removable media
        transport=$(lsblk --output TRAN -n "$mount_point" 2&gt;/dev/null)
        if [[ -n "$transport" &amp;&amp; "$transport" != "loop" ]]; then
            echo "***XYLOK ICS***"
            echo "Removable media found: $mount_point"
            echo "$line"
            removable_media_found=true
        fi
    fi
done &lt; "$fstab_file"

if [[ "$removable_media_found" == false ]]; then
    echo "***XYLOK ICS***"
    echo "No removable media found"
fi


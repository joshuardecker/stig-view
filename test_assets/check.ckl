          <VULN_ATTRIBUTE>Rule_ID</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>SV-230247r1017065_rule</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>

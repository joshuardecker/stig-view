        <STATUS>Open</STATUS>
        <FINDING_DETAILS>#echo '***XYLOK ICS***'
sysctl kernel.dmesg_restrict
echo '***XYLOK ICS***'
grep -Er '^[[:space:]]*kernel.dmesg_restrict' /run/sysctl.d/*.conf /usr/local/lib/sysctl.d/*.conf /usr/lib/sysctl.d/*.conf /lib/sysctl.d/*.conf /etc/sysctl.conf /etc/sysctl.d/*.conf 2&gt;/dev/null

Checking the value of the 'kernel.dmesg_restrict' variable:
❌ kernel.dmesg_restrict = 0

Checking config files to enable 'kernel.dmesg_restrict' variable:

          <VULN_ATTRIBUTE>Check_Content_Ref</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>M</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>
          <VULN_ATTRIBUTE>Weight</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>10.0</ATTRIBUTE_DATA>

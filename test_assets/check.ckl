        </STIG_DATA>
        <STATUS>Open</STATUS>
        <FINDING_DETAILS>##!/usr/bin/env bash
shopt -s nullglob

sys_umask=$(awk 'BEGIN{IGNORECASE=1} /^[[:space:]]*UMASK[[:space:]]+/ {print $2; exit}' /etc/login.defs)
if [[ -z $sys_umask ]]; then
  for f in /etc/profile /etc/bashrc; do
    [[ -f $f ]] || continue
    sys_umask=$(grep -i '^[[:space:]]*umask' "$f" | awk '{print $2; exit}')
    [[ -n $sys_umask ]] &amp;&amp; break
  done
fi
sys_umask=${sys_umask:-022}

while IFS=: read -r username _ _ _ _ homedir shell; do
  case "$shell" in
    /sbin/nologin|/bin/sync|/sbin/shutdown|/sbin/halt|/usr/sbin/nologin|/bin/false|/bin/true) continue ;;
  esac

  echo '***XYLOK ICS***'
  echo "#USERNAME:$username HOMEDIRECTORY:$homedir"

  found=0
  for f in "$homedir"/.[^.]*; do
    [[ -f $f ]] || continue
    grep -H -i '^[[:space:]]*umask' "$f" 2&gt;/dev/null \
      | grep -v '\.bash_history' \
      | while IFS= read -r line; do
          echo "$line"
          found=1
        done
  done

  if (( found == 0 )); then
    echo "DEFAULT UMASK: $sys_umask"
  fi

done &lt; /etc/passwd
 
Checking if the default 'umask' for all interactive users is '077':
User: deckerr :: Home Directory: /home/deckerr
❌ Default umask 022 less restrictive than '077'



Xylok post-processing completed with no errors.
</FINDING_DETAILS>
        <COMMENTS>deckerr: default umask 022 less restrictive than '077'.</COMMENTS>

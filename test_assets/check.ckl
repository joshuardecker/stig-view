        <FINDING_DETAILS>##!/usr/bin/env bash
shopt -s nullglob

while IFS=: read -r username _ uid gid _ homedir shell; do
  case "$shell" in
    /sbin/nologin|/usr/sbin/nologin|/bin/false|/bin/true) continue ;;
  esac

  echo '***XYLOK ICS***'
  echo "#USERNAME:$username HOMEDIRECTORY:$homedir PRIMARYGROUPID:$gid"

  for init in "$homedir"/.[^.]*; do
    [ -f "$init" ] || continue
    stat -c "%a:%n" "$init"
  done

done &lt; /etc/passwd

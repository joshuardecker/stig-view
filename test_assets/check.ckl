        <STATUS>NotAFinding</STATUS>
        <FINDING_DETAILS>##!/usr/bin/env bash
shopt -s nullglob

while IFS= read -r pwline; do
  IFS=: read -r username passwd uid gid gecos homedir shell &lt;&lt;&lt; "$pwline"

  # Skip non-interactive or system accounts
  case "$shell" in
    /sbin/nologin|/usr/sbin/nologin|/bin/false|/bin/true) continue ;;
  esac
  # Also skip these three special accounts by name
  case "$username" in
    sync|shutdown|halt) continue ;;
  esac

  echo '***XYLOK ICS***'
  echo "#USERNAME:$username HOMEDIRECTORY:$homedir PRIMARYGROUPID:$gid"

  # List every non-hidden entry (files *and* directories) directly under $homedir
  for f in "$homedir"/*; do
    [[ -e $f ]] || continue    # skip if the glob didn’t match anything
    stat -c "%a:%n" "$f"
  done
done &lt; /etc/passwd


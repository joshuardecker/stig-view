          <VULN_ATTRIBUTE>Rule_ID</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>SV-230402r1017208_rule</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>

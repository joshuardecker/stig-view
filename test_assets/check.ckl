        <FINDING_DETAILS>##echo '***XYLOK ICS***'
#grep 'HOME=' /etc/default/useradd
#echo '***XYLOK ICS***'
#cut -d: -f 1,3,6,7 /etc/passwd | grep -v "/sbin/nologin\|/sbin/halt\|/bin/sync\|/sbin/shutdown\|/bin/false\|/bin/true\|/usr/sbin/nologin\|root" | grep -v "^#"
#echo '***XYLOK ICS***'
#cat /etc/fstab
echo '***XYLOK ICS***'
while IFS=":" read -r username password uid gid info home shell; do
  rootDevID=$(stat -c "%d" /)
  homeDevID=$(stat -c "%d" "$home")
  echo "$username:$home:$rootDevID:$homeDevID"
done &lt; &lt;(grep -E -v "(nologin|false|true|halt|shutdown|sync|root)" /etc/passwd)

deckerr:/home/deckerr:64768:64768
❌ User: deckerr | home directory /home/deckerr not on separate partition from /



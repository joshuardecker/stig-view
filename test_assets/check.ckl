        <FINDING_DETAILS>#if [ -e /etc/firefox/policies/policies.json ];
then
    echo "/etc/firefox/policies/policies.json exists."
    echo "***XYLOK ICS***"
    cat /etc/firefox/policies/policies.json
else
    echo "/etc/firefox/policies/policies.json does not exist."
    echo "***XYLOK ICS***"
    if [ -e "$ffinstloc/distribution/policies.json" ];
    then
        echo "$ffinstloc/distribution/policies.json exists."
        echo "***XYLOK ICS***"
        cat "$ffinstloc/distribution/policies.json"
    else
        echo "$ffinstloc/distribution/policies.json does not exist."
    fi
fi


          <VULN_ATTRIBUTE>Rule_ID</VULN_ATTRIBUTE>
          <ATTRIBUTE_DATA>SV-244546r1017349_rule</ATTRIBUTE_DATA>
        </STIG_DATA>
        <STIG_DATA>

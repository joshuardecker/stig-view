        <FINDING_DETAILS>#echo '***XYLOK ICS***'
cat /etc/passwd
echo '***XYLOK ICS***'
#!/bin/bash
FILENAME="/etc/passwd"
while IFS=: read -r username password userid groupid comment homedir cmdshell
do
        if [[ "$cmdshell" != "/sbin/nologin" &amp;&amp; "$cmdshell" != "/sbin/halt" &amp;&amp; "$cmdshell" != "/bin/sync" &amp;&amp; "$cmdshell" != "/sbin/shutdown" &amp;&amp; "$cmdshell" != "/bin/false" &amp;&amp; "$cmdshell" != "/bin/true" &amp;&amp; "$cmdshell" != "/usr/sbin/nologin" ]]; then
                echo "$username"
        fi
done &lt; $FILENAME
echo '***XYLOK ICS***'
semanage user -l
echo '***XYLOK ICS***'
semanage login -l


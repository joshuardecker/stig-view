        <FINDING_DETAILS>#echo '***XYLOK ICS***'
cat /etc/passwd
echo '***XYLOK ICS***'
# Get the list of interactive user accounts
user_list=$(awk -F: '{if ($NF != "/usr/sbin/nologin" &amp;&amp; $NF != "/usr/bin/false" &amp;&amp; $NF != "/sbin/nologin" &amp;&amp; $NF != "/sbin/halt" &amp;&amp; $NF != "/bin/sync" &amp;&amp; $NF != "/sbin/shutdown" &amp;&amp; $NF != "/bin/false" &amp;&amp; $NF != "/bin/true" &amp;&amp; $NF != "/usr/sbin/nologin") print $1}' /etc/passwd)

# Loop through each interactive user account
for user in $user_list; do
    # Get the maximum password age in days for the user
    max_age=$(grep -w "$user" /etc/shadow | cut -d: -f5)
    
    # List users and their maxpasswordage
    echo "USERNAME:$user \t MAXPASSWORDAGE:$max_age"
done

Checking maximum password lifetime for interactive users:
❌ USERNAME:root \t MAXPASSWORDAGE:99999
❌ USERNAME:deckerr \t MAXPASSWORDAGE:99999


Xylok post-processing completed with no errors.
</FINDING_DETAILS>
        <COMMENTS>The following interactive users have a maximum password lifetime greater than 60 days or is not restricted at all:
root
deckerr</COMMENTS>
